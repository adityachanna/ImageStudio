# -------------------------------
# Frontend + backend bridge URL
# -------------------------------
# Server-side route handlers should use this in production.
JDI_BACKEND_URL=https://your-fastapi-domain.example.com

# Client-side components can use this (must be public-safe).
NEXT_PUBLIC_JDI_BACKEND_URL=https://your-fastapi-domain.example.com

# -------------------------------
# MongoDB (pick one URI key)
# -------------------------------
# Preferred key:
MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/?appName=Cluster0

# Backward-compatible key still read by current code:
# uri=mongodb+srv://user:password@cluster.example.mongodb.net/?appName=Cluster0

# Optional database override (default: ticketing)
MONGODB_DATABASE=ticketing
MONGO_DB_NAME=ticketing

# Optional Mongo timeout tuning (milliseconds)
MONGO_SERVER_SELECTION_TIMEOUT_MS=8000
MONGO_CONNECT_TIMEOUT_MS=8000
MONGO_SOCKET_TIMEOUT_MS=8000

# -------------------------------
# Cloudflare R2 / S3-compatible
# -------------------------------
# Endpoint (either S3_API or R2_ENDPOINT)
S3_API=https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Access key (either S3_ACCESS_KEY_ID or AWS_ACCESS_KEY_ID)
S3_ACCESS_KEY_ID=your-r2-access-key-id
AWS_ACCESS_KEY_ID=your-r2-access-key-id

# Secret key (either Secret_Access_Key or AWS_SECRET_ACCESS_KEY)
Secret_Access_Key=your-r2-secret-access-key
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Bucket (any one of these is accepted)
Bucket=your-bucket-name
R2_BUCKET_NAME=your-bucket-name
AWS_BUCKET_NAME=your-bucket-name
